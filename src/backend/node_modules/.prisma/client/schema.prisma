// ConsorcioPro — Prisma Schema
// Banco: PostgreSQL 16

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// USUÁRIOS E AUTENTICAÇÃO
// ─────────────────────────────────────────

model Usuario {
  id           String        @id @default(uuid())
  email        String        @unique
  celular      String        @unique
  nome         String
  cpfHash      String        @unique // CPF criptografado one-way
  senha        String // bcrypt hash
  role         Role          @default(CONSORCIADO)
  status       StatusUsuario @default(PENDENTE_KYC)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  participantes Participante[]
  sessoes       Sessao[]

  @@map("usuarios")
}

model Sessao {
  id           String   @id @default(uuid())
  usuarioId    String
  refreshToken String   @unique
  expiresAt    DateTime
  criadoEm     DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("sessoes")
}

// ─────────────────────────────────────────
// GRUPOS
// ─────────────────────────────────────────

model Grupo {
  id                     String      @id @default(uuid())
  codigo                 String      @unique
  categoria              Categoria
  valorCredito           Decimal     @db.Decimal(15, 2)
  totalParticipantes     Int
  participantesAtivos    Int         @default(0)
  prazoMeses             Int
  taxaAdminPercentual    Decimal     @db.Decimal(5, 2)
  fundoReservaPercentual Decimal     @db.Decimal(5, 2)
  status                 StatusGrupo @default(FORMANDO)
  dataInicio             DateTime?
  criadoEm               DateTime    @default(now())
  atualizadoEm           DateTime    @updatedAt

  participantes Participante[]
  assembleias   Assembleia[]

  @@map("grupos")
}

// ─────────────────────────────────────────
// PARTICIPANTES
// ─────────────────────────────────────────

model Participante {
  id               String             @id @default(uuid())
  grupoId          String
  usuarioId        String
  numeroCota       Int
  status           StatusParticipante @default(ATIVO)
  valorCredito     Decimal            @db.Decimal(15, 2)
  percentualPago   Decimal            @default(0) @db.Decimal(5, 2)
  dataAdesao       DateTime           @default(now())
  dataContemplacao DateTime?
  tipoContemplacao TipoContemplacao?
  criadoEm         DateTime           @default(now())

  grupo         Grupo          @relation(fields: [grupoId], references: [id])
  usuario       Usuario        @relation(fields: [usuarioId], references: [id])
  parcelas      Parcela[]
  lances        Lance[]
  cartasCredito CartaCredito[]

  @@unique([grupoId, numeroCota])
  @@map("participantes")
}

// ─────────────────────────────────────────
// ASSEMBLEIAS
// ─────────────────────────────────────────

model Assembleia {
  id               String           @id @default(uuid())
  grupoId          String
  numero           Int
  dataRealizacao   DateTime
  status           StatusAssembleia @default(AGENDADA)
  seedSorteio      String?
  commitment       String? // hash SHA-256 do seed (publicado 48h antes)
  resultadoSorteio Json?
  ataUrl           String?
  criadoEm         DateTime         @default(now())

  grupo    Grupo     @relation(fields: [grupoId], references: [id])
  parcelas Parcela[]
  lances   Lance[]

  @@unique([grupoId, numero])
  @@map("assembleias")
}

// ─────────────────────────────────────────
// FINANCEIRO
// ─────────────────────────────────────────

model Parcela {
  id                String           @id @default(uuid())
  participanteId    String
  assembleiaId      String?
  numero            Int
  valorPrincipal    Decimal          @db.Decimal(15, 2)
  valorFundoComum   Decimal          @db.Decimal(15, 2)
  valorFundoReserva Decimal          @db.Decimal(15, 2)
  valorTaxaAdmin    Decimal          @db.Decimal(15, 2)
  valorSeguro       Decimal          @default(0) @db.Decimal(15, 2)
  valorTotal        Decimal          @db.Decimal(15, 2)
  status            StatusParcela    @default(PENDENTE)
  dataVencimento    DateTime         @db.Date
  dataPagamento     DateTime?
  metodoPagamento   MetodoPagamento?
  txidPix           String?
  criadoEm          DateTime         @default(now())

  participante Participante @relation(fields: [participanteId], references: [id])
  assembleia   Assembleia?  @relation(fields: [assembleiaId], references: [id])

  @@map("parcelas")
}

model Lance {
  id              String      @id @default(uuid())
  assembleiaId    String
  participanteId  String
  tipo            TipoLance
  valorOfertado   Decimal     @db.Decimal(15, 2)
  percentualCarta Decimal     @db.Decimal(5, 2)
  status          StatusLance @default(PENDENTE)
  criadoEm        DateTime    @default(now())

  assembleia   Assembleia   @relation(fields: [assembleiaId], references: [id])
  participante Participante @relation(fields: [participanteId], references: [id])

  @@map("lances")
}

// ─────────────────────────────────────────
// CONTEMPLAÇÃO
// ─────────────────────────────────────────

model CartaCredito {
  id             String      @id @default(uuid())
  participanteId String
  valor          Decimal     @db.Decimal(15, 2)
  status         StatusCarta @default(PENDENTE_ANALISE)
  dataAprovacao  DateTime?
  dataValidade   DateTime    @db.Date
  tipoBem        String?
  valorBem       Decimal?    @db.Decimal(15, 2)
  criadoEm       DateTime    @default(now())

  participante Participante @relation(fields: [participanteId], references: [id])

  @@map("cartas_credito")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  GESTOR
  CONSORCIADO
  READONLY
}

enum StatusUsuario {
  PENDENTE_KYC
  ATIVO
  BLOQUEADO
  CANCELADO
}

enum Categoria {
  imovel
  veiculo_leve
  veiculo_pesado
  servico
  moto
}

enum StatusGrupo {
  FORMANDO
  ATIVO
  ENCERRADO
}

enum StatusParticipante {
  ATIVO
  INADIMPLENTE
  CONTEMPLADO
  DESISTENTE
  EXCLUIDO
}

enum TipoContemplacao {
  SORTEIO
  LANCE_LIVRE
  LANCE_EMBUTIDO
}

enum StatusAssembleia {
  AGENDADA
  EM_ANDAMENTO
  REALIZADA
  CANCELADA
}

enum StatusParcela {
  PENDENTE
  PAGA
  VENCIDA
  CANCELADA
}

enum MetodoPagamento {
  pix
  boleto
  debito
}

enum TipoLance {
  LIVRE
  EMBUTIDO
  FIXO
}

enum StatusLance {
  PENDENTE
  VENCEDOR
  PERDEDOR
  CANCELADO
}

enum StatusCarta {
  PENDENTE_ANALISE
  APROVADA
  EM_USO
  UTILIZADA
  EXPIRADA
}
